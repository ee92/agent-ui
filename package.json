{
  "name": "agent-ui",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agent-ui": "./bin/agent-ui.mjs"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^7.1.0",
    "vite-plugin-pwa": "^1.0.3",
    "vitest": "^4.0.0",
    "workbox-window": "^7.4.0"
  },
  "description": "A self-hosted dashboard for AI agent workflows. Works with Claude Code, OpenClaw, and more.",
  "files": [
    "bin/",
    "dist/",
    "server/",
    "serve.mjs",
    "public/",
    "index.html",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "dashboard",
    "claude-code",
    "openclaw",
    "task-board"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ee92/agent-ui.git"
